{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": true,
    },
    "higgsfield": {
      "type": "remote",
      "url": "https://mcp.higgsfield.ai/mcp",
      "enabled": true,
    },
  },
}
